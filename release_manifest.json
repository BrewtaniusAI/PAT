{
  "name": "PAT",
  "version": "1.0.0",
  "release_stage": "public-alpha",
  "artifacts": [
    "README.md",
    "LICENSE.md",
    "CITATION.cff",
    "pyproject.toml",
    "VERSION",
    "schemas/pipeline_output.schema.json",
    "release_manifest.json",
    "docs/GITHUB_RELEASE_DRAFT.md",
    "docs/ZENODO_RELEASE_NOTES.md",
    "provenance.json",
    "docs/PUBLICATION_CHECKLIST.md",
    "docs/GITHUB_RELEASE_TEXT.md",
    "docs/ZENODO_PUBLICATION_TEXT.md",
    "docs/REPOSITORY_METADATA.md",
    ".github/workflows/release.yml",
    "provenance.signed.example.json",
    "docs/SIGNED_PROVENANCE.md",
    "docs/LANDING_PAGE.md",
    "docs/INDEX.md",
    "mkdocs.yml",
    "docs/FIRST_PUBLIC_RELEASE_CHECKLIST.md"
